<%# app/views/shared/resource_form/fields/_select.html.erb %>
<%
  param_key = model&.model_name&.param_key || "resource"
  field_name = field[:field].to_s
  field_id = "#{param_key}_#{field_name}"
  has_dependency = field[:depends_on].present?
  error_message = model&.errors&.[](field_name.to_sym)&.first
  placeholder = resolve_placeholder(field) || "선택하세요"
  use_tom_select = field[:tom_select] != false
  ts_searchable = field[:searchable].nil? ? true : !!field[:searchable]

  current_value = if field.key?(:value)
    field[:value]
  elsif model&.respond_to?(field_name)
    model.public_send(field_name)
  end

  selected_values = if field[:multi]
    Array(current_value).map(&:to_s)
  else
    [current_value.to_s]
  end

  select_classes = ["form-grid-select"]
  if error_message.present?
    select_classes << "rf-field-error"
  end
%>

<div class="flex flex-col gap-1 col-span-24 min-w-0 <%= span_classes_for(field, cols: cols) %>"
     data-resource-form-target="<%= has_dependency ? 'fieldGroup dependentField' : 'fieldGroup' %>"
     data-field-name="<%= field_name %>">
  <label class="text-sm font-medium text-text-secondary" for="<%= field_id %>">
    <%= resolve_label(field) %>
    <% if field[:required] %><span class="text-accent-rose ml-0.5 font-semibold">*</span><% end %>
  </label>

  <div class="flex relative">
    <select id="<%= field_id %>"
            name="<%= "#{param_key}[#{field_name}]" %>"
            class="<%= select_classes.join(' ') %>"
            <%= "required" if field[:required] %>
            <%= "disabled" if field[:disabled] || field[:readonly] %>
            <%= "multiple" if field[:multi] %>
            <% if use_tom_select %>
              data-controller="tom-select"
              data-tom-select-searchable-value="<%= ts_searchable %>"
              data-tom-select-multi-value="<%= !!field[:multi] %>"
              data-tom-select-placeholder-value="<%= placeholder %>"
            <% end %>
            <% if has_dependency %>
              data-all-options="<%= (field[:options] || []).to_json %>"
              data-depends-on="<%= field[:depends_on] %>"
              data-depends-filter="<%= field[:depends_filter] || field[:depends_on] %>"
            <% end %>
            <% if field[:target].present? && local_assigns[:target_controller].present? %>
              data-<%= local_assigns[:target_controller].to_s.dasherize %>-target="<%= field[:target] %>"
            <% end %>
            data-resource-form-target="input"
            data-action="<%= has_dependency ? '' : 'change->resource-form#onSelectChange ' %>blur->resource-form#validateField">
      <% if field[:include_blank] != false %>
        <option value=""><%= placeholder %></option>
      <% end %>

      <% (field[:options] || []).each do |opt| %>
        <%
          label, value = if opt.is_a?(Hash)
            [opt[:label] || opt["label"], opt[:value] || opt["value"]]
          elsif opt.is_a?(Array)
            [opt.first, opt.last]
          else
            [opt, opt]
          end
          value_text = value.to_s
        %>
        <option value="<%= value %>" <%= "selected" if selected_values.include?(value_text) %>><%= label %></option>
      <% end %>
    </select>
  </div>

  <span class="rf-error-msg <%= 'invisible' if error_message.blank? %>"><%= error_message.presence || " " %></span>
  <% if field[:help].present? %>
    <span class="text-xs text-text-muted mt-0.5"><%= field[:help] %></span>
  <% end %>
</div>
