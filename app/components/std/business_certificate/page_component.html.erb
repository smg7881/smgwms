<div data-controller="std-business-certificate-crud"
     data-std-business-certificate-crud-create-url-value="<%= create_url %>"
     data-std-business-certificate-crud-update-url-value="<%= update_url %>"
     data-std-business-certificate-crud-delete-url-value="<%= delete_url %>"
     data-std-business-certificate-crud-client-defaults-url-value="<%= client_defaults_url %>">
  <%= render Ui::SearchFormComponent.new(
    url: create_url,
    fields: search_fields,
    cols: 3,
    enable_collapse: true
  ) %>

  <%= render Ui::GridHeaderComponent.new(
    icon: "id-card", title: "사업자등록증 목록", grid_id: "std-business-certificate",
    buttons: [
      { label: "신규등록", class: "btn btn-sm btn-primary", action: "click->std-business-certificate-crud#openCreate" }
    ]
  ) %>

  <%= render Ui::AgGridComponent.new(
    columns: columns,
    url: grid_url,
    height: "calc(100vh - 370px)",
    page_size: 20,
    grid_id: "std-business-certificate"
  ) %>

  <%= render Ui::ModalShellComponent.new(
    controller: "std-business-certificate-crud",
    title: "사업자등록증 등록",
    save_form_id: "std-business-certificate-crud-form",
    cancel_role: "cancel",
    save_role: "save",
    width: "920px"
  ) do |modal| %>
    <% modal.with_body do %>
      <input type="hidden" data-std-business-certificate-crud-target="fieldId" />

      <%= render Ui::ResourceFormComponent.new(
        model: StdBusinessCertificate.new,
        url: "#",
        cols: 2,
        show_buttons: false,
        target_controller: "std_business_certificate_crud",
        fields: form_fields,
        form_data: {
          std_business_certificate_crud_target: "form",
          action: "submit->resource-form#submit submit->std-business-certificate-crud#submit"
        },
        form_html: {
          id: "std-business-certificate-crud-form",
          novalidate: true,
          autocomplete: "off"
        }
      ) %>
    <% end %>
  <% end %>
</div>
