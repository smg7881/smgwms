<div class="std-client-screen om-service-order-screen"
     data-controller="om-service-order-form"
     data-action="ag-grid:ready->om-service-order-form#registerGrid"
     data-om-service-order-form-detail-batch-url-template-value="<%= detail_batch_save_url_template %>"
     data-om-service-order-form-detail-list-url-template-value="<%= detail_list_url_template %>"
     data-om-service-order-form-selected-order-value="<%= selected_order.to_s %>">
  <%= render Ui::SearchFormComponent.new(
    url: create_url,
    fields: search_fields,
    cols: 4,
    enable_collapse: true,
    class: "std-client-search"
  ) %>

  <section class="std-client-master">
    <%= render Ui::GridHeaderComponent.new(
      icon: "clipboard-list", title: "서비스 오더 목록", grid_id: "om-service-order-master",
      class: "std-client-section-head", title_class: "std-client-section-title", icon_class: "w-4 h-4",
      buttons: [
        { label: "오더취소", class: "btn btn-sm btn-danger", action: "click->om-service-order-form#cancelSelectedOrder" }
      ]
    ) %>

    <%= render Ui::AgGridComponent.new(
      columns: master_columns,
      url: grid_url,
      height: "250px",
      page_size: 20,
      row_selection: "single",
      grid_id: "om-service-order-master",
      data: { om_service_order_form_target: "masterGrid" }
    ) %>
  </section>

  <section class="std-client-detail">
    <%= render Ui::GridHeaderComponent.new(
      icon: "list-tree", title: "오더 상세", grid_id: "om-service-order-detail",
      class: "std-client-section-head", title_class: "std-client-section-title", icon_class: "w-4 h-4",
      buttons: [
        { label: "행추가", class: "btn btn-sm btn-primary", action: "click->om-service-order-form#addDetailRow" },
        { label: "행삭제", class: "btn btn-sm btn-danger", action: "click->om-service-order-form#deleteDetailRows" },
        { label: "저장", class: "btn btn-sm btn-success", action: "click->om-service-order-form#saveDetailRows" }
      ]
    ) do |header| %>
      <% header.with_subtitle do %>
        <p class="text-text-secondary text-xs" data-om-service-order-form-target="selectedOrderLabel"><%= selected_order_label %></p>
      <% end %>
    <% end %>

    <% if detail_grid_url.present? %>
      <%= render Ui::AgGridComponent.new(
        columns: detail_columns,
        url: detail_grid_url,
        height: "300px",
        pagination: false,
        row_selection: "multiple",
        grid_id: "om-service-order-detail",
        data: { om_service_order_form_target: "detailGrid" }
      ) %>
    <% else %>
      <%= render Ui::AgGridComponent.new(
        columns: detail_columns,
        row_data: [],
        height: "300px",
        pagination: false,
        row_selection: "multiple",
        grid_id: "om-service-order-detail",
        data: { om_service_order_form_target: "detailGrid" }
      ) %>
    <% end %>
  </section>
</div>
