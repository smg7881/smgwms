<div class="std-client-screen om-internal-order-screen"
     data-controller="om-internal-order"
     data-action="ag-grid:ready->om-internal-order#registerGrid"
     data-om-internal-order-master-batch-url-value="<%= master_batch_save_url %>"
     data-om-internal-order-item-list-url-template-value="<%= item_list_url_template %>"
     data-om-internal-order-selected-order-value="<%= selected_order.to_s %>">
  <%= render Ui::SearchFormComponent.new(
    url: create_url,
    fields: search_fields,
    cols: 4,
    enable_collapse: true,
    class: "std-client-search"
  ) %>

  <section class="std-client-master">
    <%= render Ui::GridHeaderComponent.new(
      icon: "clipboard-list", title: "내부오더 목록", grid_id: "om-internal-order-master",
      class: "std-client-section-head", title_class: "std-client-section-title", icon_class: "w-4 h-4",
      buttons: [
        { label: "행추가", class: "btn btn-sm btn-primary", action: "click->om-internal-order#addMasterRow" },
        { label: "행삭제", class: "btn btn-sm btn-danger", action: "click->om-internal-order#deleteMasterRows" },
        { label: "저장", class: "btn btn-sm btn-success", action: "click->om-internal-order#saveMasterRows" }
      ]
    ) %>

    <%= render Ui::AgGridComponent.new(
      columns: master_columns,
      url: grid_url,
      height: "250px",
      page_size: 20,
      row_selection: "multiple",
      grid_id: "om-internal-order-master",
      data: { om_internal_order_target: "masterGrid" }
    ) %>
  </section>

  <section class="std-client-detail">
    <div class="std-client-selected" data-om-internal-order-target="selectedOrderLabel"><%= selected_order_label %></div>

    <%= render Ui::ResourceFormComponent.new(
      model: detail_form_model,
      url: "#",
      cols: 4,
      show_buttons: false,
      target_controller: "om_internal_order",
      fields: header_form_fields,
      form_data: detail_form_data,
      form_html: {
        id: "om-internal-order-header-form",
        autocomplete: "off",
        novalidate: true
      },
      class: "std-client-resource-form"
    ) %>

    <%= render Ui::TabsComponent.new(
      target_controller: "om-internal-order",
      tabs: [
        { id: "location", label: "출도착지" },
        { id: "items", label: "아이템" }
      ]
    ) %>

    <div class="std-client-panel is-active" data-om-internal-order-target="tabPanel" data-tab-panel="location">
      <%= render Ui::ResourceFormComponent.new(
        model: detail_form_model,
        url: "#",
        cols: 2,
        show_buttons: false,
        target_controller: "om_internal_order",
        fields: location_form_fields,
        form_data: detail_form_data,
        form_html: {
          id: "om-internal-order-location-form",
          autocomplete: "off",
          novalidate: true
        },
        class: "std-client-resource-form"
      ) %>
    </div>

    <div class="std-client-panel" data-om-internal-order-target="tabPanel" data-tab-panel="items" hidden>
      <%= render Ui::GridHeaderComponent.new(
        icon: "list", title: "아이템 목록 (최대 20건)", grid_id: "om-internal-order-items",
        class: "std-client-section-head", title_class: "std-client-section-title", icon_class: "w-4 h-4",
        buttons: [
          { label: "행추가", class: "btn btn-sm btn-primary", action: "click->om-internal-order#addItemRow" },
          { label: "행삭제", class: "btn btn-sm btn-danger", action: "click->om-internal-order#deleteItemRows" }
        ]
      ) %>

      <%= render Ui::AgGridComponent.new(
        columns: item_columns,
        row_data: [],
        height: "300px",
        pagination: false,
        row_selection: "multiple",
        grid_id: "om-internal-order-items",
        data: { om_internal_order_target: "itemsGrid" }
      ) %>
    </div>
  </section>
</div>

