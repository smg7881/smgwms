<div class="om-waiting-order-screen"
     data-controller="om-waiting-order-grid"
     data-action="ag-grid:ready->om-waiting-order-grid#registerGrid"
     data-om-waiting-order-grid-detail-list-url-template-value="<%= detail_list_url_template %>"
     data-om-waiting-order-grid-detail-batch-url-template-value="<%= detail_batch_save_url_template %>">
  <%= render Ui::SearchFormComponent.new(
    url: create_url,
    fields: search_fields,
    cols: 4,
    enable_collapse: true
  ) %>

  <section class="mt-4">
    <%= render Ui::GridHeaderComponent.new(
      icon: "list", title: "대기오더목록", grid_id: "om-waiting-order-master",
      class: "flex items-center justify-between gap-3 mb-3 mt-2"
    ) %>

    <%= render Ui::AgGridComponent.new(
      columns: master_columns,
      url: grid_url,
      height: "260px",
      page_size: 20,
      row_selection: "single",
      grid_id: "om-waiting-order-master",
      data: { om_waiting_order_grid_target: "masterGrid" }
    ) %>
  </section>

  <section class="mt-5">
    <%= render Ui::GridHeaderComponent.new(
      icon: "list-tree", title: "대기오더상세", grid_id: "om-waiting-order-detail",
      class: "flex items-center justify-between gap-3 mb-3 mt-2",
      buttons: [
        { label: "가용재고조회", class: "btn btn-sm btn-secondary", action: "click->om-waiting-order-grid#checkAvailableStock" },
        { label: "오더분배", class: "btn btn-sm btn-primary", action: "click->om-waiting-order-grid#distributeDetailRows" }
      ]
    ) do |header| %>
      <% header.with_subtitle do %>
        <p class="text-text-secondary text-xs" data-om-waiting-order-grid-target="selectedOrderLabel"><%= selected_order_label %></p>
      <% end %>
    <% end %>

    <%= render Ui::AgGridComponent.new(
      columns: detail_columns,
      row_data: [],
      height: "calc(100vh - 500px)",
      pagination: false,
      row_selection: "single",
      grid_id: "om-waiting-order-detail",
      data: { om_waiting_order_grid_target: "detailGrid" }
    ) %>
  </section>
</div>
