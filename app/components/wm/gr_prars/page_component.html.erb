<div class="std-client-screen"
     data-controller="wm-gr-prar-grid"
     data-action="ag-grid:ready->wm-gr-prar-grid#registerGrid"
     data-wm-gr-prar-grid-master-batch-url-value="<%= master_batch_save_url %>"
     data-wm-gr-prar-grid-detail-batch-url-template-value="<%= detail_batch_save_url_template %>"
     data-wm-gr-prar-grid-detail-list-url-template-value="<%= detail_list_url_template %>"
     data-wm-gr-prar-grid-exec-result-url-template-value="<%= exec_result_list_url_template %>"
     data-wm-gr-prar-grid-save-url-template-value="<%= save_url_template %>"
     data-wm-gr-prar-grid-confirm-url-template-value="<%= confirm_url_template %>"
     data-wm-gr-prar-grid-cancel-url-template-value="<%= cancel_url_template %>"
     data-wm-gr-prar-grid-generate-url-value="<%= generate_url %>"
     data-wm-gr-prar-grid-staged-locations-url-value="<%= staged_locations_url %>"
     data-wm-gr-prar-grid-selected-master-value="<%= selected_gr_prar_no.to_s %>">
  <%= render Ui::SearchFormComponent.new(
    url: collection_path,
    fields: search_fields,
    cols: 4,
    enable_collapse: true,
    class: "std-client-search"
  ) %>

  <section class="std-client-master">
    <%= render Ui::GridHeaderComponent.new(
      icon: "package-open",
      title: "입고예정 목록",
      grid_id: "gr-prar-master",
      class: "std-client-section-head",
      title_class: "std-client-section-title",
      icon_class: "w-4 h-4"
    ) %>

    <%= render Ui::AgGridComponent.new(
      columns: master_columns,
      url: collection_path(format: :json),
      height: "260px",
      pagination: true,
      row_selection: "single",
      grid_id: "gr-prar-master",
      data: { wm_gr_prar_grid_target: "masterGrid" }
    ) %>
  </section>

  <section class="std-client-detail">
    <div class="std-client-selected" data-wm-gr-prar-grid-target="selectedMasterLabel"><%= selected_master_label %></div>

    <%= render Ui::TabsComponent.new(
      target_controller: "wm-gr-prar-grid",
      tabs: [
        { id: "detail", label: "입고예정상세" },
        { id: "exec", label: "입고처리이력" }
      ]
    ) %>

    <div class="std-client-panel is-active" data-wm-gr-prar-grid-target="tabPanel" data-tab-panel="detail">
      <%= render Ui::GridHeaderComponent.new(
        icon: "list-checks",
        title: "입고예정 상세",
        grid_id: "gr-prar-detail",
        class: "std-client-section-head",
        title_class: "std-client-section-title",
        icon_class: "w-4 h-4",
        buttons: [
          { label: "입고예정생성", class: "btn btn-sm btn-secondary", action: "click->wm-gr-prar-grid#generatePrar" },
          { label: "저장", class: "btn btn-sm btn-primary", action: "click->wm-gr-prar-grid#saveGr" },
          { label: "입고확정", class: "btn btn-sm btn-success", action: "click->wm-gr-prar-grid#confirmGr" },
          { label: "입고취소", class: "btn btn-sm btn-danger", action: "click->wm-gr-prar-grid#cancelGr" }
        ]
      ) %>

      <% if selected_gr_prar_no.present? %>
        <%= render Ui::AgGridComponent.new(
          columns: detail_columns,
          url: "/wm/gr_prars/#{selected_gr_prar_no}/details.json",
          height: "260px",
          pagination: false,
          row_selection: "single",
          grid_id: "gr-prar-detail",
          data: { wm_gr_prar_grid_target: "detailGrid" }
        ) %>
      <% else %>
        <%= render Ui::AgGridComponent.new(
          columns: detail_columns,
          row_data: [],
          height: "260px",
          pagination: false,
          row_selection: "single",
          grid_id: "gr-prar-detail",
          data: { wm_gr_prar_grid_target: "detailGrid" }
        ) %>
      <% end %>
    </div>

    <div class="std-client-panel" data-wm-gr-prar-grid-target="tabPanel" data-tab-panel="exec" hidden>
      <%= render Ui::GridHeaderComponent.new(
        icon: "clipboard-list",
        title: "입고처리 이력",
        grid_id: "gr-prar-exec-result",
        class: "std-client-section-head",
        title_class: "std-client-section-title",
        icon_class: "w-4 h-4",
        buttons: [
          { label: "입고예정생성", class: "btn btn-sm btn-secondary", action: "click->wm-gr-prar-grid#generatePrar" },
          { label: "저장", class: "btn btn-sm btn-primary", action: "click->wm-gr-prar-grid#saveGr" },
          { label: "입고확정", class: "btn btn-sm btn-success", action: "click->wm-gr-prar-grid#confirmGr" },
          { label: "입고취소", class: "btn btn-sm btn-danger", action: "click->wm-gr-prar-grid#cancelGr" }
        ]
      ) %>

      <% if selected_gr_prar_no.present? %>
        <%= render Ui::AgGridComponent.new(
          columns: exec_result_columns,
          url: "/wm/gr_prars/#{selected_gr_prar_no}/exec_results.json",
          height: "260px",
          pagination: false,
          grid_id: "gr-prar-exec-result",
          data: { wm_gr_prar_grid_target: "execRsltGrid" }
        ) %>
      <% else %>
        <%= render Ui::AgGridComponent.new(
          columns: exec_result_columns,
          row_data: [],
          height: "260px",
          pagination: false,
          grid_id: "gr-prar-exec-result",
          data: { wm_gr_prar_grid_target: "execRsltGrid" }
        ) %>
      <% end %>
    </div>
  </section>
</div>
